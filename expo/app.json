{
  "expo": {
    "name": "Unbreakable Vow",
    "slug": "unbreakable-vow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "unbreakablevow",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.unbreakablevow.ios",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleTypeRole": "Editor",
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.543817344565-b2tg6eonrbglhot5rccd87e8vot4b69p"
            ]
          }
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "app.unbreakablevow.android"
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://unbreakablevow.app"
        }
      ],
      "expo-font",
      "expo-web-browser",
      ["@stripe/stripe-react-native", {
        "merchantIdentifier": "merchant.app.unbreakablevow",
        "enableGooglePay": false
      }],
      ["@react-native-google-signin/google-signin", {
        "iosUrlScheme": "com.googleusercontent.apps.543817344565-b2tg6eonrbglhot5rccd87e8vot4b69p"
      }],
      [
        "expo-contacts",
        {
          "contactsPermission": "Unbreakable Vow needs access to your contacts so you can choose a witness."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}